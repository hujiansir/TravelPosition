<!--index.wxml-->
<view class="map-page">
  <map
    class="map"
    longitude="{{center.longitude}}"
    latitude="{{center.latitude}}"
    scale="{{scale}}"
    polygons="{{polygons}}"
    show-location
    enable-zoom
    enable-scroll
  ></map>

  <view class="stats">
    <view class="stat-item">
      <text class="stat-num">{{litCityCount}}</text>
      <text class="stat-label">个城市</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{litProvinceCount}}</text>
      <text class="stat-label">个省份</text>
    </view>
  </view>

  <view class="checkin-btn" bindtap="goCheckin">
    <text class="checkin-icon">＋</text>
    <text class="checkin-text">打卡</text>
  </view>

  <view wx:if="{{loading}}" class="loading-mask">
    <text>加载中...</text>
  </view>
</view>
