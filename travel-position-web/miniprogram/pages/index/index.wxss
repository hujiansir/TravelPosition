/**index.wxss**/
page {
  height: 100vh;
}

.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
}

.map {
  width: 100%;
  height: 100%;
}

.stats {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  display: flex;
  background: rgba(14, 26, 43, 0.88);
  border-radius: 16rpx;
  padding: 16rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
}

.stat-item {
  display: flex;
  align-items: baseline;
  margin-right: 40rpx;
}

.stat-item:last-child {
  margin-right: 0;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #00E5FF;
}

.stat-label {
  font-size: 24rpx;
  color: #9DB2C7;
  margin-left: 8rpx;
}

.checkin-btn {
  position: absolute;
  right: 40rpx;
  bottom: 100rpx;
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #FFC107;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(255, 193, 7, 0.55);
}

.checkin-icon {
  font-size: 48rpx;
  color: #fff;
  line-height: 1;
}

.checkin-text {
  font-size: 24rpx;
  color: #fff;
  margin-top: 4rpx;
}

.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(14, 26, 43, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9DB2C7;
  font-size: 28rpx;
}
