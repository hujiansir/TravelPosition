/**checkin.wxss**/
page {
  background: #f5f5f5;
}

.checkin-page {
  padding: 24rpx;
}

.location-card,
.note-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.loc-title,
.note-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.loc-coord {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.loc-hint {
  font-size: 24rpx;
  color: #FFC107;
  margin-top: 12rpx;
}

.loc-status {
  font-size: 28rpx;
  color: #999;
}

.loc-retry {
  font-size: 28rpx;
  color: #FFC107;
  margin-top: 12rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  color: #333;
}

.checkin-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #FFC107;
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  margin-top: 32rpx;
  border: none;
}

.checkin-submit.disabled {
  background: #ccc;
}
