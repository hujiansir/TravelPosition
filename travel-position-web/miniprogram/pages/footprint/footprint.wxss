/**footprint.wxss**/
page {
  background: #f5f5f5;
}

.footprint-page {
  padding: 24rpx;
  min-height: 100vh;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 200rpx 0;
}

.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FFC107;
  margin-top: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
}

.item-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.item-city {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.item-province {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.item-note {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-time {
  font-size: 24rpx;
  color: #aaa;
}

.item-del {
  font-size: 24rpx;
  color: #e57373;
}

.loading-tip {
  text-align: center;
  color: #aaa;
  font-size: 24rpx;
  padding: 24rpx;
}
